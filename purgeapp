#!/usr/bin/env zsh

# purgeapp — completely remove a macOS app and all its leftover files
# https://github.com/SiavoshZarrasvand/homebrew-purgeapp

VERSION="1.0.2"

# ── Colours ──────────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
RESET='\033[0m'

# ── Help ─────────────────────────────────────────────────────────────────────
usage() {
  echo ""
  echo "${BOLD}purgeapp${RESET} v${VERSION} — completely remove a macOS app and all its leftovers"
  echo ""
  echo "${BOLD}Usage:${RESET}"
  echo "  purgeapp <AppName>         # with or without .app"
  echo "  purgeapp Workpuls"
  echo "  purgeapp Workpuls.app"
  echo ""
  echo "${BOLD}Options:${RESET}"
  echo "  -d, --dry-run    Show what would be removed without deleting anything"
  echo "  -v, --version    Print version"
  echo "  -h, --help       Show this help message"
  echo ""
}

# ── Argument parsing ──────────────────────────────────────────────────────────
DRY_RUN=false

for arg in "$@"; do
  case $arg in
    -h|--help)    usage; exit 0 ;;
    -v|--version) echo "purgeapp v${VERSION}"; exit 0 ;;
    -d|--dry-run) DRY_RUN=true ;;
  esac
done

APP_RAW="${@:#-*}"
APP_RAW="${APP_RAW// /}"

if [[ -z "$APP_RAW" ]]; then
  echo "${RED}Error:${RESET} No app name provided."
  usage
  exit 1
fi

APP_NAME="${APP_RAW%.app}"
APP_LOWER=$(echo "$APP_NAME" | tr '[:upper:]' '[:lower:]')
APP_BUNDLE="/Applications/${APP_NAME}.app"

# ── Helpers ───────────────────────────────────────────────────────────────────
removed_count=0
not_found_count=0
failed_count=0
failed_paths=()

safe_remove() {
  local target="$1"
  local use_sudo="${2:-auto}"   # auto | yes | no

  if [[ -e "$target" || -L "$target" ]]; then
    if $DRY_RUN; then
      echo "  ${YELLOW}[dry-run]${RESET} Would remove: $target"
      (( removed_count++ ))
      return
    fi

    # Determine whether to use sudo:
    # - always sudo for /Library and /Applications (system paths)
    # - never sudo for ~/Library/Containers and ~/Library/Group Containers
    #   (TCC-protected; sudo makes it worse, not better)
    # - otherwise use sudo for anything outside $HOME
    local do_sudo=false
    if [[ "$use_sudo" == "yes" ]]; then
      do_sudo=true
    elif [[ "$use_sudo" == "no" ]]; then
      do_sudo=false
    elif [[ "$target" == /Library/* || "$target" == /Applications/* || "$target" == /System/* ]]; then
      do_sudo=true
    elif [[ "$target" != "$HOME"* ]]; then
      do_sudo=true
    fi

    local cmd="rm -rf"
    $do_sudo && cmd="sudo rm -rf"

    if eval "$cmd \"$target\"" 2>/dev/null; then
      echo "  ${GREEN}✓${RESET} Removed: $target"
      (( removed_count++ ))
    else
      echo "  ${RED}✗${RESET} Failed: $target"
      failed_paths+=("$target")
      (( failed_count++ ))
    fi
  else
    (( not_found_count++ ))
  fi
}

safe_remove_glob() {
  local pattern="$1"
  local use_sudo="${2:-auto}"
  setopt local_options nullglob
  for match in ${~pattern}; do
    safe_remove "$match" "$use_sudo"
  done
}

# ── Header ────────────────────────────────────────────────────────────────────
echo ""
echo "${BOLD}${BLUE}purgeapp${RESET} — purging ${BOLD}${APP_NAME}${RESET}"
$DRY_RUN && echo "${YELLOW}  Dry-run mode: nothing will actually be deleted${RESET}"
echo ""

# ── 1. Kill processes ─────────────────────────────────────────────────────────
echo "${BOLD}Stopping processes...${RESET}"
if pgrep -fi "$APP_NAME" > /dev/null 2>&1; then
  if $DRY_RUN; then
    echo "  ${YELLOW}[dry-run]${RESET} Would kill processes matching: $APP_NAME"
  else
    sudo pkill -fi "$APP_NAME" 2>/dev/null
    sleep 1
    echo "  ${GREEN}✓${RESET} Killed running processes"
  fi
else
  echo "  No running processes found for ${APP_NAME}"
fi
echo ""

# ── 2. App bundle ─────────────────────────────────────────────────────────────
echo "${BOLD}Removing app bundle...${RESET}"
if [[ -d "$APP_BUNDLE" ]]; then
  safe_remove "$APP_BUNDLE"
else
  echo "  ${YELLOW}⚠${RESET}  App bundle not found at ${APP_BUNDLE}"
  echo "     (may have been removed manually — continuing to clean up leftovers)"
fi
echo ""

# ── 3. User Library ───────────────────────────────────────────────────────────
echo "${BOLD}Removing user Library files...${RESET}"

USER_PATHS=(
  "$HOME/Library/Application Support/${APP_NAME}"
  "$HOME/Library/Application Support/${APP_LOWER}"
  "$HOME/Library/Application Support/${APP_LOWER}-agent"
  "$HOME/Library/Application Support/${APP_NAME}-agent"
  "$HOME/Library/Caches/${APP_NAME}"
  "$HOME/Library/Caches/${APP_LOWER}"
  "$HOME/Library/Caches/${APP_LOWER}-agent"
  "$HOME/Library/Logs/${APP_NAME}"
  "$HOME/Library/Logs/${APP_LOWER}"
  "$HOME/Library/Logs/${APP_LOWER}-agent"
  "$HOME/Library/Saved Application State/${APP_LOWER}.savedState"
  "$HOME/Library/WebKit/${APP_LOWER}"
  "$HOME/Library/Cookies/${APP_LOWER}.binarycookies"
  "$HOME/Library/HTTPStorages/${APP_LOWER}"
)

for path in "${USER_PATHS[@]}"; do
  safe_remove "$path"
done

safe_remove_glob "$HOME/Library/Preferences/com.${APP_LOWER}.*"
safe_remove_glob "$HOME/Library/Preferences/${APP_NAME}*"
safe_remove_glob "$HOME/Library/Containers/com.${APP_LOWER}*"
safe_remove_glob "$HOME/Library/Group Containers/*${APP_LOWER}*"
safe_remove_glob "$HOME/Library/Caches/com.${APP_LOWER}.*"
safe_remove_glob "$HOME/Library/LaunchAgents/com.${APP_LOWER}.*"
echo ""

# ── 4. System Library ─────────────────────────────────────────────────────────
echo "${BOLD}Removing system-level files...${RESET}"

SYSTEM_PATHS=(
  "/Library/Application Support/${APP_NAME}"
  "/Library/Application Support/${APP_LOWER}"
  "/Library/Application Support/${APP_LOWER}-agent"
  "/Library/Logs/${APP_NAME}"
  "/Library/Logs/${APP_LOWER}"
)

for path in "${SYSTEM_PATHS[@]}"; do
  safe_remove "$path"
done

safe_remove_glob "/Library/LaunchAgents/com.${APP_LOWER}.*"
safe_remove_glob "/Library/LaunchDaemons/com.${APP_LOWER}.*"
safe_remove_glob "/Library/PrivilegedHelperTools/com.${APP_LOWER}.*"
safe_remove_glob "/Library/Extensions/*${APP_LOWER}*"
echo ""

# ── 5. Unload launch services ─────────────────────────────────────────────────
echo "${BOLD}Unloading launch services...${RESET}"
if $DRY_RUN; then
  echo "  ${YELLOW}[dry-run]${RESET} Would unload launchctl entries for com.${APP_LOWER}"
else
  launchctl remove "com.${APP_LOWER}.agent" 2>/dev/null
  launchctl remove "com.${APP_LOWER}" 2>/dev/null
  sudo launchctl remove "com.${APP_LOWER}.daemon" 2>/dev/null
  sudo launchctl remove "com.${APP_LOWER}" 2>/dev/null
  echo "  ${GREEN}✓${RESET} Launch services unloaded (if any existed)"
fi
echo ""

# ── 6. Residual scan ──────────────────────────────────────────────────────────
echo "${BOLD}Scanning for any remaining traces...${RESET}"
LEFTOVERS=$(sudo find /Users /Library /Applications \
  -iname "*${APP_LOWER}*" \
  -not -path "*/Trash/*" \
  -not -path "*/.git/*" \
  2>/dev/null)

if [[ -n "$LEFTOVERS" ]]; then
  echo "  ${YELLOW}⚠  The following files may need manual review:${RESET}"
  echo "$LEFTOVERS" | while read -r line; do
    echo "     $line"
  done
else
  echo "  ${GREEN}✓${RESET} No remaining traces found"
fi
echo ""

# ── Summary ───────────────────────────────────────────────────────────────────
echo "────────────────────────────────────────"
if $DRY_RUN; then
  echo "${YELLOW}Dry run complete.${RESET} Run without ${BOLD}-d${RESET} to actually delete."
else
  if [[ $failed_count -eq 0 ]]; then
    echo "${GREEN}${BOLD}✅ purgeapp complete.${RESET}"
  else
    echo "${YELLOW}${BOLD}⚠  purgeapp finished with some failures.${RESET}"
  fi
  echo "   Removed  : ${removed_count}"
  echo "   Not found: ${not_found_count} (already clean or never existed)"
  if [[ $failed_count -gt 0 ]]; then
    echo "   Failed   : ${failed_count}"
    echo ""
    echo "${YELLOW}The following paths could not be removed:${RESET}"
    for p in "${failed_paths[@]}"; do
      echo "   $p"
    done
    echo ""
    echo "${BOLD}These are likely protected by macOS TCC (Full Disk Access).${RESET}"
    echo "To remove them, grant your Terminal Full Disk Access first:"
    echo ""
    echo "  1. Open ${BOLD}System Settings → Privacy & Security → Full Disk Access${RESET}"
    echo "  2. Enable your terminal app (Terminal, iTerm2, etc.)"
    echo "  3. Re-run: ${BOLD}purgeapp ${APP_NAME}${RESET}"
  fi
fi
echo ""
